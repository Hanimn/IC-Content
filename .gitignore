# Validator deps — installed in CI via `npm install` from the manifest in
# .github/scripts/package.json. We intentionally do NOT commit a lockfile
# (this is a 3-package CI-only manifest; pinned ^semver in package.json is
# sufficient and avoids Dependabot churn on a content repo).
/.github/scripts/node_modules/
/.github/scripts/package-lock.json
